---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

interface Props {
  label?: string;
  title: string;
  subtitle: string;
  showCalculator?: boolean;
  showStats?: boolean;
}

const {
  label,
  title,
  subtitle,
  showCalculator = false,
  showStats = false,
} = Astro.props;
---

<section class="relative py-20 md:py-32 lg:py-40 overflow-hidden">
  <!-- Animated Gradient Background -->
  <div class="absolute inset-0 -z-10 bg-dot-pattern" />

  <!-- Glow Orbs (Animated) -->
  <div
    id="orb-1"
    class="absolute top-20 right-10 w-72 h-72 bg-peb-cyan/20 rounded-full blur-3xl opacity-30 animate-pulse"
  />
  <div
    id="orb-2"
    class="absolute bottom-20 left-20 w-96 h-96 bg-peb-blue/15 rounded-full blur-3xl opacity-20 animate-pulse"
  />
  <div
    id="orb-3"
    class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-peb-green/10 rounded-full blur-3xl opacity-20 animate-pulse"
  />

  <!-- Content -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div class="space-y-8 reveal">
        {
          label && (
            <div class="inline-flex items-center space-x-3">
              <div class="w-2 h-2 rounded-full bg-peb-cyan animate-pulse-dot" />
              <span class="text-sm font-medium text-peb-cyan uppercase tracking-wider">
                {label}
              </span>
            </div>
          )
        }

        <h1 class="text-5xl sm:text-6xl md:text-7xl font-display font-bold leading-tight">
          <span class="gradient-text-cyan">{title}</span>
        </h1>

        <p class="text-lg sm:text-xl text-peb-text2 leading-relaxed max-w-lg">
          {subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <Button href="/contact/" variant="primary" size="lg" hasArrow>
            Prendre rendez-vous
          </Button>
          <Button href="/guide-peb/" variant="secondary" size="lg" hasArrow>
            En savoir plus
          </Button>
        </div>

        <!-- Trust Signals -->
        <div class="flex flex-wrap gap-3 pt-8 border-t border-peb-border">
          <Badge variant="cyan" text="✓ Agréé" />
          <Badge variant="green" text="⚡ Rapide" />
          <Badge variant="blue" text="€ Sans frais cachés" />
        </div>
      </div>

      <!-- Right Side: Calculator or Stats -->
      {
        showCalculator ? (
          <div class="reveal-right">
            <div class="bg-peb-card border border-peb-border rounded-2xl p-8 glass-hover">
              <div class="flex items-center justify-between mb-6">
                <h3 class="text-2xl font-display font-bold text-peb-text">
                  Devis <span class="text-peb-cyan">instantané</span>
                </h3>
                <Badge variant="green" text="Sans engagement" />
              </div>

              <!-- Calculator Tabs -->
              <div class="space-y-6">
                <div>
                  <label class="text-sm font-semibold text-peb-text mb-4 block uppercase tracking-wider">
                    Type de bien
                  </label>
                  <div class="grid grid-cols-3 gap-2" id="calc-tabs">
                    <button
                      data-type="appartement"
                      data-min="18"
                      data-max="450"
                      data-default="50"
                      class="px-4 py-2.5 rounded-lg bg-gradient-to-r from-peb-blue to-peb-cyan text-peb-bg font-semibold text-sm transition-all calc-tab active"
                    >
                      Appartement
                    </button>
                    <button
                      data-type="duplex"
                      data-min="50"
                      data-max="450"
                      data-default="100"
                      class="px-4 py-2.5 rounded-lg border border-peb-border text-peb-text2 font-medium text-sm hover:border-peb-cyan transition-all calc-tab"
                    >
                      Duplex+
                    </button>
                    <button
                      data-type="maison"
                      data-min="60"
                      data-max="450"
                      data-default="120"
                      class="px-4 py-2.5 rounded-lg border border-peb-border text-peb-text2 font-medium text-sm hover:border-peb-cyan transition-all calc-tab"
                    >
                      Maison
                    </button>
                  </div>
                </div>

                <!-- Surface Range Slider -->
                <div>
                  <div class="flex items-center justify-between mb-3">
                    <label class="text-sm font-semibold text-peb-text uppercase tracking-wider">
                      Superficie
                    </label>
                    <span
                      class="text-lg font-bold text-peb-cyan font-mono"
                      id="sqm-display"
                    >
                      50 m²
                    </span>
                  </div>
                  <input
                    type="range"
                    id="calc-slider"
                    min="18"
                    max="450"
                    value="50"
                    class="w-full"
                    aria-label="Superficie en mètres carrés"
                  />
                  <div class="flex justify-between text-xs text-peb-text2 mt-2">
                    <span>18 m²</span>
                    <span>450 m²</span>
                  </div>
                </div>

                <!-- Price Display -->
                <div class="bg-peb-bg border border-peb-border rounded-xl p-6 text-center space-y-2">
                  <div class="text-xs text-peb-text2 uppercase tracking-wider">Votre prix fixe</div>
                  <div class="flex items-baseline justify-center gap-1">
                    <span
                      id="price-display"
                      class="text-5xl font-display font-extrabold text-white"
                      style="transition: all 0.3s ease"
                    >
                      105
                    </span>
                    <span class="text-xl text-peb-text2 font-medium">€</span>
                  </div>
                  <div class="text-xs text-peb-text2">
                    TTC — Tout compris
                  </div>
                </div>

                <!-- CTA Button -->
                <a href="/contact/" class="flex items-center justify-center gap-2 w-full px-8 py-4 rounded-lg bg-gradient-to-r from-peb-blue to-peb-cyan text-peb-bg font-semibold text-lg transition-all hover:shadow-lg hover:shadow-peb-cyan/20 active:scale-95">
                  Prendre rendez-vous
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </a>

                <p class="text-center text-xs text-peb-muted mt-2">
                  Disponible sous 24h · Déplacement gratuit · Agréé n°001862747
                </p>
              </div>
            </div>
          </div>
        ) : null
      }

      {
        showStats ? (
          <div class="reveal-right grid grid-cols-2 gap-6">
            <div class="bg-peb-card border border-peb-border rounded-2xl p-6 text-center">
              <div class="text-4xl font-display font-bold text-peb-cyan mb-2 counter" data-target="1000">
                0
              </div>
              <p class="text-sm text-peb-text2">Certificats complétés</p>
            </div>

            <div class="bg-peb-card border border-peb-border rounded-2xl p-6 text-center">
              <div class="text-4xl font-display font-bold text-peb-green mb-2">
                98%
              </div>
              <p class="text-sm text-peb-text2">Satisfaction client</p>
            </div>

            <div class="bg-peb-card border border-peb-border rounded-2xl p-6 text-center">
              <div class="text-4xl font-display font-bold text-peb-blue mb-2">
                24h
              </div>
              <p class="text-sm text-peb-text2">RDV disponibles</p>
            </div>

            <div class="bg-peb-card border border-peb-border rounded-2xl p-6 text-center">
              <div class="text-4xl font-display font-bold text-peb-cyan mb-2">
                4+
              </div>
              <p class="text-sm text-peb-text2">Années d'expertise</p>
            </div>
          </div>
        ) : null
      }
    </div>
  </div>

  <!-- Calculator + Parallax Script -->
  <script>
    // === Parallax effect on glow orbs ===
    var orbs = [
      document.getElementById('orb-1'),
      document.getElementById('orb-2'),
      document.getElementById('orb-3')
    ];
    if (window.innerWidth > 768) {
      document.addEventListener('mousemove', function(e) {
        var mx = e.clientX / window.innerWidth - 0.5;
        var my = e.clientY / window.innerHeight - 0.5;
        orbs.forEach(function(orb, i) {
          if (orb) {
            var f = (i === 0) ? 1 : (i === 1) ? -0.6 : 0.4;
            orb.style.transform = 'translate(' + (mx * 30 * f) + 'px,' + (my * 30 * f) + 'px)';
          }
        });
      });
    }

    // === Calculator with real PEBify pricing tiers ===
    var pricing = {
      appartement: [
        { max: 50, price: 105 },
        { max: 85, price: 125 },
        { max: 120, price: 145 },
        { max: 175, price: 165 },
        { max: 250, price: 185 },
        { max: 450, price: 215 }
      ],
      duplex: [
        { max: 80, price: 225 },
        { max: 120, price: 245 },
        { max: 175, price: 265 },
        { max: 250, price: 295 },
        { max: 450, price: 325 }
      ],
      maison: [
        { max: 100, price: 235 },
        { max: 150, price: 265 },
        { max: 200, price: 295 },
        { max: 300, price: 325 },
        { max: 450, price: 355 }
      ]
    };

    var currentType = 'appartement';
    var calcSlider = document.getElementById('calc-slider');
    var sqmDisplay = document.getElementById('sqm-display');
    var priceDisplay = document.getElementById('price-display');
    var calcTabs = document.querySelectorAll('.calc-tab');

    function getPrice(type, sqm) {
      var tiers = pricing[type] || pricing.appartement;
      for (var i = 0; i < tiers.length; i++) {
        if (sqm <= tiers[i].max) return tiers[i].price;
      }
      return tiers[tiers.length - 1].price;
    }

    function updateCalc() {
      if (!calcSlider || !priceDisplay || !sqmDisplay) return;
      var val = parseInt(calcSlider.value);
      sqmDisplay.textContent = val + ' m\u00B2';
      var price = getPrice(currentType, val);
      priceDisplay.textContent = price;

      // Update slider track gradient fill
      var min = parseInt(calcSlider.min);
      var max = parseInt(calcSlider.max);
      var pct = ((val - min) / (max - min)) * 100;
      calcSlider.style.background = 'linear-gradient(to right, #0066FF 0%, #00D4FF ' + pct + '%, #111620 ' + pct + '%)';
    }

    // Tab click handlers
    calcTabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        // Reset all tabs
        calcTabs.forEach(function(t) {
          t.classList.remove('bg-gradient-to-r', 'from-peb-blue', 'to-peb-cyan', 'text-peb-bg', 'font-semibold');
          t.classList.add('border', 'border-peb-border', 'text-peb-text2', 'font-medium');
        });
        // Activate clicked tab
        tab.classList.remove('border', 'border-peb-border', 'text-peb-text2', 'font-medium');
        tab.classList.add('bg-gradient-to-r', 'from-peb-blue', 'to-peb-cyan', 'text-peb-bg', 'font-semibold');

        currentType = tab.dataset.type || 'appartement';

        // Adjust slider range per type
        if (calcSlider) {
          calcSlider.min = tab.dataset.min || '18';
          calcSlider.max = tab.dataset.max || '450';
          calcSlider.value = tab.dataset.default || '50';
        }
        updateCalc();
      });
    });

    // Slider input handler
    if (calcSlider) {
      calcSlider.addEventListener('input', updateCalc);
      // Initial update
      updateCalc();
    }

    // === Counter animation ===
    var counters = document.querySelectorAll('.counter');
    counters.forEach(function(counter) {
      var target = parseInt(counter.getAttribute('data-target') || '0');
      var current = 0;
      var increment = target / 30;
      var timer = setInterval(function() {
        current += increment;
        if (current >= target) { current = target; clearInterval(timer); }
        counter.textContent = Math.floor(current).toLocaleString();
      }, 30);
    });
  </script>
