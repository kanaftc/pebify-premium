---
interface Stat {
  icon: string;
  number: string;
  label: string;
}

interface Props {}

const stats: Stat[] = [
  {
    icon: '⚡',
    number: '24h',
    label: 'RDV disponibles',
  },
  {
    icon: '✓',
    number: '100%',
    label: 'Agréé région',
  },
  {
    icon: '€',
    number: '0€',
    label: 'Frais cachés',
  },
  {
    icon: '📅',
    number: '10 ans',
    label: 'Validité cert.',
  },
];
---

<section class="py-12 sm:py-16 md:py-20 bg-peb-surface border-y border-peb-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8 reveal-stagger">
      {
        stats.map((stat) => (
          <div
            class="bg-peb-card border border-peb-border rounded-xl p-6 text-center hover:bg-peb-card-hover hover:border-peb-cyan/20 transition-all duration-200 reveal"
          >
            <div class="text-4xl mb-3">{stat.icon}</div>
            <div class="text-3xl sm:text-4xl font-display font-bold text-peb-cyan mb-2">
              {stat.number}
            </div>
            <p class="text-sm text-peb-text2">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
