  </svg>
</a>

<style is:global>
  @media (max-width: 768px) {
    a[aria-label="Chat with us on WhatsApp"] {
      @apply bottom-6 right-6 w-12 h-12;
    }

    a[aria-label="Chat with us on WhatsApp"] svg {
      @apply w-5 h-5;
    }
