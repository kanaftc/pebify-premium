---
interface Props {}

const navLinks = [
  { label: 'Tarifs PEB', href: '/tarifs-peb-bruxelles/' },
  { label: 'Guide PEB', href: '/guide-peb/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'FAQ', href: '/faq/' },
  { label: 'À propos', href: '/a-propos/' },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-50 nav-light transition-all duration-300"
  id="navbar"
  role="navigation"
  aria-label="Navigation principale"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="flex items-center justify-between h-14">
      <!-- Logo (anthracite on light bg) -->
      <a
        href="/"
        class="flex items-center transition-all duration-200 hover:opacity-85"
        aria-label="PEBify — Accueil"
      >
        <img
          src="/pebify-premium/images/logo-header.webp"
          alt="PEBify — Certificateur PEB Bruxelles"
          class="h-9 md:h-11 w-auto"
          width="160"
          height="44"
        />
      </a>

      <!-- Desktop Navigation Links -->
      <div class="hidden lg:flex items-center space-x-8">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-peb-text2-dark hover:text-peb-blue transition-colors text-sm font-medium relative group"
            >
              {link.label}
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-gradient-to-r from-peb-blue to-peb-cyan group-hover:w-full transition-all duration-300" />
            </a>
          ))
        }
      </div>

      <!-- CTA Button & Mobile Menu Trigger -->
      <div class="flex items-center space-x-4">
        <a
          href="/contact/"
          class="hidden lg:inline-flex items-center space-x-2 px-6 py-2.5 rounded-lg bg-gradient-to-r from-peb-blue-deep to-peb-blue text-white font-semibold text-sm transition-all duration-200 hover:shadow-lg active:scale-95"
        >
          <span>Prendre RDV</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>

        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-peb-blue hover:bg-peb-surface transition-colors"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div
    id="mobile-menu"
    class="hidden fixed top-14 left-0 right-0 bg-white/98 backdrop-blur-lg border-b border-peb-border-light lg:hidden"
    role="navigation"
    aria-label="Navigation mobile"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 space-y-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block px-4 py-3 rounded-lg text-peb-text-dark hover:bg-peb-surface hover:text-peb-blue transition-colors font-medium"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact/"
        class="block px-4 py-3 rounded-lg bg-gradient-to-r from-peb-blue-deep to-peb-blue text-white font-semibold text-center mt-3"
      >
        Prendre RDV
      </a>
    </div>
  </div>
</nav>

<script>
  var navbar = document.getElementById('navbar');
  var mobileMenuBtn = document.getElementById('mobile-menu-btn');
  var mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', function() {
    if (window.scrollY > 30) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  }, { passive: true });

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', function() {
      var isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', String(!isOpen));
    });
    mobileMenu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        mobileMenu.classList.add('hidden');
        mobileMenuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
