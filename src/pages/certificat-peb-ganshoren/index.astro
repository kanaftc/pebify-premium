---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CommuneLinks from '../../components/sections/CommuneLinks.astro';

const faqItems = [
  {
    question: 'Ma maison résidentielle à Ganshoren est-elle facile à certifier?',
    answer: 'Oui, les maisons résidentielles de Ganshoren se certifient facilement. Je maîtrise parfaitement l\'architecture typique de cette commune. Mon expertise permet une certification rapide et précise.'
  },
  {
    question: 'Quel est le potentiel d\'amélioration énergétique à Ganshoren?',
    answer: 'Les maisons de Ganshoren, construites au début du XXe siècle, offrent un excellent potentiel. L\'amélioration de l\'isolation, des vitrages et du chauffage peut transformer significativement votre performance énergétique.'
  },
  {
    question: 'Quel délai pour mon certificat PEB à Ganshoren?',
    answer: 'J\'obtiens généralement votre certificat en 3 à 5 jours après la visite. Ganshoren est mon territoire de prédilection, avec nombreuses propriétés que j\'ai déjà certifiées.'
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PEBify - Certificat PEB Ganshoren",
  "description": "Expert en certification PEB agréé à Ganshoren (1083)",
  "url": "https://pebify.be/certificat-peb-ganshoren/",
  "areaServed": { "@type": "City", "name": "Ganshoren", "postalCode": "1083" },
  "priceRange": "€€"
};
---

<PageLayout
  title="Certificat PEB Ganshoren (1083) — Dès 189€ | Certificateur Agréé"
  description="Expert en certification PEB à Ganshoren (1083). Certificats énergétiques agréés pour maisons unifamiliales et petits collectifs. Service rapide et fiable."
  breadcrumb={[{ label: 'Certificat PEB Ganshoren', href: '/certificat-peb-ganshoren/' }]}
  heroLabel="Certification PEB"
  heroTitle="Certificat PEB à Ganshoren"
  heroSubtitle="Certificateur agréé pour vos propriétés ganshoroises. Expert en maisons résidentielles et petits collectifs."
  canonical="https://pebify.be/certificat-peb-ganshoren/"
  schemaJson={jsonLd}
>
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-6 text-peb-text">
          Certificat PEB à <span class="gradient-text-cyan">Ganshoren</span>
        </h2>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Ganshoren, petite commune du nord-ouest bruxellois, offre un cadre résidentiel tranquille dominé par l'habitat individuel. Avec environ 27 000 habitants, elle représente une zone essentiellement constituée de maisons de quartier et de petits collectifs. L'ambiance paisible du Parc de Ganshoren et de la Chaussée de Gand caractérisent cette commune attachante.
        </p>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Je certifie régulièrement les propriétés ganshoroises avec une expertise approfondie. Les maisons résidentielles typiques de Ganshoren, caractérisées par une belle architecture bruxelloise traditionnelle, offrent des possibilités intéressantes de rénovation énergétique performante.
        </p>
      </div>

      <div class="bg-peb-surface border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Types de propriétés à Ganshoren
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Maisons unifamiliales</p>
              <p class="text-peb-text2 text-sm">Certification de maisons particulières typiques de Ganshoren.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Petits collectifs</p>
              <p class="text-peb-text2 text-sm">Immeubles résidentiels de petite taille très présents.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Habitats résidentiels</p>
              <p class="text-peb-text2 text-sm">Certification de structures d'habitation variées.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Demeures bourgeoises</p>
              <p class="text-peb-text2 text-sm">Certification de propriétés de prestige local.</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Profil énergétique à Ganshoren
        </h3>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Les propriétés ganshoroises obtiennent généralement des classifications PEB entre D et F, reflétant l'âge des constructions typiques de la commune. Les maisons datent souvent du début du XXe siècle avec peu d'améliorations énergétiques.
        </p>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Ganshoren offre un excellent potentiel de rénovation énergétique. L'amélioration de l'isolation, des vitrages et du chauffage central peut transformer significativement votre classement PEB et réduire vos charges énergétiques.
        </p>
      </div>

      <div class="bg-peb-card border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Services de certification à Ganshoren
        </h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Certificat PEB agréé</h4>
            <p class="text-peb-text2 text-sm">Certification officielle pour tous types de biens ganshorois.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Audit énergétique</h4>
            <p class="text-peb-text2 text-sm">Analyse avec recommandations adaptées à votre propriété.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Rapport complet</h4>
            <p class="text-peb-text2 text-sm">Documentation détaillée avec stratégies d'amélioration.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Consultation</h4>
            <p class="text-peb-text2 text-sm">Expertise spécialisée pour maisons résidentielles.</p>
          </div>
        </div>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Tarification
        </h3>
        <div class="grid sm:grid-cols-3 gap-4 mb-6">
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Petit bien</p>
            <p class="text-3xl font-bold text-peb-cyan">189€</p>
          </div>
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Duplex</p>
            <p class="text-3xl font-bold text-peb-cyan">219€</p>
          </div>
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Maison</p>
            <p class="text-3xl font-bold text-peb-cyan">249€</p>
          </div>
        </div>
        <p class="text-peb-text2 mb-4">
          <a href="/contact/" class="text-peb-cyan hover:text-peb-green font-medium transition-colors">Contactez-moi</a> pour votre devis.
        </p>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Ressources
        </h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/guide-peb/definition/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Qu'est-ce que le PEB?</p>
            <p class="text-sm text-peb-text2">Comprendre la certification.</p>
          </a>
          <a href="/guide-peb/ameliorer-score/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Améliorer votre score</p>
            <p class="text-sm text-peb-text2">Recommandations d'amélioration.</p>
          </a>
          <a href="/guide-peb/echelle-classes/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Classes énergétiques</p>
            <p class="text-sm text-peb-text2">Échelle A++ à G.</p>
          </a>
          <a href="/guide-peb/primes/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Aides rénovation</p>
            <p class="text-sm text-peb-text2">Primes 2026.</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} />

  <CTA
    title="Certificat PEB à Ganshoren"
    subtitle="Contactez-moi pour votre certification énergétique à Ganshoren."
    primaryHref="/contact/"
    primaryText="Demander un devis"
    secondaryHref="/guide-peb/"
    secondaryText="En savoir plus"
  />

  <CommuneLinks />
</PageLayout>
