---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CommuneLinks from '../../components/sections/CommuneLinks.astro';

const faqItems = [
  {
    question: 'Comment certifier un petit immeuble à Schaerbeek avec 4 unités?',
    answer: 'Les petits immeubles de Schaerbeek se certifient complètement. Je maîtrise l\'architecture schaerbeekoise. Ma spécialité concerne ces structures multi-unités présentes partout dans la commune.'
  },
  {
    question: 'Quel profil énergétique typique à Schaerbeek?',
    answer: 'Schaerbeek présente une grande diversité. Les petits immeubles et maisons de quartier obtiennent généralement D à F. Les rénovations peuvent améliorer significativement la performance.'
  },
  {
    question: 'Quel tarif pour une multi-propriété à Schaerbeek?',
    answer: 'Pour les petits immeubles à Schaerbeek, je propose des forfaits adaptés au nombre d\'unités. Contactez-moi pour un devis basé sur votre situation spécifique.'
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PEBify - Certificat PEB Schaerbeek",
  "description": "Expert en certification PEB agréé à Schaerbeek (1030)",
  "url": "https://pebify.be/certificat-peb-schaerbeek/",
  "areaServed": { "@type": "City", "name": "Schaerbeek", "postalCode": "1030" },
  "priceRange": "€€"
};
---

<PageLayout
  title="Certificat PEB Schaerbeek (1030) — Dès 189€ | Certificateur Agréé"
  description="Expert en certification PEB à Schaerbeek (1030). Certificats énergétiques agréés pour petits immeubles, maisons de quartier et logements collectifs. Service spécialisé."
  breadcrumb={[{ label: 'Certificat PEB Schaerbeek', href: '/certificat-peb-schaerbeek/' }]}
  heroLabel="Certification PEB"
  heroTitle="Certificat PEB à Schaerbeek"
  heroSubtitle="Certificateur agréé pour vos propriétés schaerbeekoise. Expert en petits immeubles et habitats collectifs."
  canonical="https://pebify.be/certificat-peb-schaerbeek/"
  schemaJson={jsonLd}
>
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-6 text-peb-text">
          Certificat PEB à <span class="gradient-text-cyan">Schaerbeek</span>
        </h2>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Schaerbeek, grande commune du nord-est bruxellois, conjugue l'héritage urbain avec une modernité croissante. Avec plus de 129 000 habitants, elle constitue un territoire densément peuplé offrant un habitat extrêmement diversifié : petits immeubles d'habitation, maisons de quartier, logements collectifs et petits bâtiments commerciaux.
        </p>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Je certifie régulièrement les propriétés schaerbeekoise avec expertise approfondie. Ma spécialité concerne les petits immeubles et logements collectifs typiques de Schaerbeek, dominants dans la commune.
        </p>
      </div>

      <div class="bg-peb-surface border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Propriétés à Schaerbeek
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Petits immeubles</p>
              <p class="text-peb-text2 text-sm">Certification d'immeubles résidentiels de 3-5 étages.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Maisons de quartier</p>
              <p class="text-peb-text2 text-sm">Certification de petites maisons schaerbeekoise.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Logements collectifs</p>
              <p class="text-peb-text2 text-sm">Certification d'immeubles collectifs variés.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Petits commerces</p>
              <p class="text-peb-text2 text-sm">Certification de structures commerciales.</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Profil énergétique
        </h3>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Schaerbeek présente un portefeuille énergétique varié. Les immeubles anciens obtiennent généralement D à F. L\'amélioration progressive offre d\'excellentes perspectives.</p>
      </div>

      <div class="bg-peb-card border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Services
        </h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Certificat PEB</h4>
            <p class="text-peb-text2 text-sm">Certification officielle.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Audit énergétique</h4>
            <p class="text-peb-text2 text-sm">Analyse avec recommandations.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Rapport complet</h4>
            <p class="text-peb-text2 text-sm">Documentation stratégique.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Consultation collectif</h4>
            <p class="text-peb-text2 text-sm">Expertise multi-unités.</p>
          </div>
        </div>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Tarification
        </h3>
        <div class="grid sm:grid-cols-3 gap-4 mb-6">
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Petit bien</p>
            <p class="text-3xl font-bold text-peb-cyan">189€</p>
          </div>
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Duplex</p>
            <p class="text-3xl font-bold text-peb-cyan">219€</p>
          </div>
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Maison</p>
            <p class="text-3xl font-bold text-peb-cyan">249€</p>
          </div>
        </div>
        <p class="text-peb-text2 mb-4">
          <a href="/contact/" class="text-peb-cyan hover:text-peb-green font-medium transition-colors">Demandez un devis</a>.
        </p>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Ressources
        </h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/guide-peb/definition/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Qu'est-ce que le PEB?</p>
            <p class="text-sm text-peb-text2">Comprendre.</p>
          </a>
          <a href="/guide-peb/ameliorer-score/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Améliorer votre score</p>
            <p class="text-sm text-peb-text2">Recommandations.</p>
          </a>
          <a href="/guide-peb/echelle-classes/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Classes énergétiques</p>
            <p class="text-sm text-peb-text2">A++ à G.</p>
          </a>
          <a href="/guide-peb/primes/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Aides rénovation</p>
            <p class="text-sm text-peb-text2">Primes 2026.</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} />

  <CTA
    title="Certificat PEB à Schaerbeek"
    subtitle="Contactez-moi pour votre certification énergétique."
    primaryHref="/contact/"
    primaryText="Demander un devis"
    secondaryHref="/guide-peb/"
    secondaryText="En savoir plus"
  />

  <CommuneLinks />
</PageLayout>
