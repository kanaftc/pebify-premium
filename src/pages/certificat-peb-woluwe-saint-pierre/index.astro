import CommuneLinks from '../../components/sections/CommuneLinks.astro';

const faqItems = [
  {
    question: 'Comment certifier une villa auprès de la Forêt de Soignes à Woluwe-Saint-Pierre?',
    answer: 'Les villas de Woluwe-Saint-Pierre, même auprès de la Forêt de Soignes, se certifient de manière standard. La proximité de la forêt n\'affecte pas la certification. Je maîtrise l\'architecture typique woluwéenne-pierroise.'
  },
  {
    question: 'Quel profil énergétique pour les villas de Woluwe-Saint-Pierre?',
    answer: 'Les villas obtiennent généralement C à F. L\'environnement naturel préservé reflète souvent des propriétés bien entretenues offrant bon potentiel d\'amélioration significative.'
  },
  {
    question: 'Quel tarif pour une grande villa à Woluwe-Saint-Pierre?',
    answer: 'Pour les villas de Woluwe-Saint-Pierre, mon tarif est 249€ minimum. Contactez-moi pour les propriétés exceptionnelles. Je maîtrise bien ce territoire élégant.'
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PEBify - Certificat PEB Woluwe-Saint-Pierre",
  "description": "Expert en certification PEB agréé à Woluwe-Saint-Pierre (1150)",
  "url": "https://pebify.be/certificat-peb-woluwe-saint-pierre/",
  "areaServed": { "@type": "City", "name": "Woluwe-Saint-Pierre", "postalCode": "1150" },
  "priceRange": "€€€"
};
