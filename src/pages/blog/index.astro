---
import PageLayout from '../../layouts/PageLayout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import CTA from '../../components/sections/CTA.astro';
import { siteConfig } from '../../data/site';

const breadcrumb = [
  { label: 'Blog', href: '/blog/' },
];

const articles = [
  {
    id: 1,
    title: 'Réforme PEB 2026: Nouveautés à connaître',
    excerpt: 'Les changements réguliers en matière de performance énergétique affectent vos obligations légales et les tarifs des certificats. Découvrez les nouveautés de 2026.',
    date: '19 mars 2026',
    slug: 'reforme-peb-2026',
    icon: '📋',
    category: 'Actualités',
  },
  {
    id: 2,
    title: 'Directive PEB Européenne 2026',
    excerpt: 'La nouvelle directive européenne sur la performance énergétique renforce les exigences pour tous les états membres. Ce que cela signifie pour la Belgique.',
    date: '12 mars 2026',
    slug: 'directive-peb-2026',
    icon: '🌍',
    category: 'Actualités',
  },
  {
    id: 3,
    title: 'Comment est calculé un devis PEB?',
    excerpt: 'Comprendre les facteurs qui influencent le prix de votre certificat énergétique. Transparence totale sur la tarification PEB.',
    date: '5 mars 2026',
    slug: 'calcul-devis-peb',
    icon: '💰',
    category: 'Guide',
  },
];
---

<PageLayout
  title="Blog - Actualités et guides PEB"
  description="Blog PEBify. Articles sur le certificat PEB, performance énergétique, actualités et guides pratiques pour Bruxelles."
  canonical="https://pebify.be/blog/"
  breadcrumb={breadcrumb}
  heroLabel="Notre blog"
  heroTitle="Actualités et guides PEB"
  heroSubtitle="Restez informé sur les évolutions du certificat PEB, les réformes et les conseils d'amélioration énergétique."
>
  <!-- Articles Grid -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal-stagger">
        {articles.map((article) => (
          <a href={`/blog/${article.slug}/`} class="group">
            <Card hover={true}>
              <div class="space-y-4 h-full flex flex-col">
                <div class="h-40 bg-gradient-to-br from-peb-cyan/20 to-peb-blue/20 rounded-lg flex items-center justify-center">
                  <span class="text-6xl">{article.icon}</span>
                </div>

                <div class="space-y-2 flex-1">
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold text-peb-cyan uppercase tracking-wider">
                      {article.category}
                    </span>
                    <span class="text-xs text-peb-text2">{article.date}</span>
                  </div>

                  <h3 class="text-xl font-display font-bold text-peb-text group-hover:text-peb-cyan transition-colors">
                    {article.title}
                  </h3>

                  <p class="text-peb-text2 text-sm leading-relaxed">
                    {article.excerpt}
                  </p>
                </div>

                <Button variant="secondary" size="sm" hasArrow class="w-full">
                  Lire l'article
                </Button>
              </div>
            </Card>
          </a>
        ))}
      </div>

      <div class="mt-16 text-center reveal">
        <p class="text-peb-text2 mb-6">
          Nous ajoutons régulièrement de nouveaux articles. Consultez notre blog chaque mois pour les dernières actualités PEB.
        </p>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-surface border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-peb-card border border-peb-border rounded-2xl p-8 sm:p-12 space-y-6 text-center reveal">
        <h2 class="text-3xl font-display font-bold text-peb-text">
          Recevez les actualités PEB
        </h2>

        <p class="text-peb-text2">
          Inscrivez-vous pour être notifié des nouveaux articles et des mises à jour réglementaires.
        </p>

        <form class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            placeholder="votre@email.com"
            required
            class="flex-1 px-4 py-3 rounded-lg bg-peb-bg border border-peb-border text-peb-text placeholder:text-peb-text2 focus:border-peb-cyan focus:outline-none"
          />
          <button
            type="submit"
            class="px-8 py-3 rounded-lg bg-gradient-to-r from-peb-blue to-peb-cyan text-peb-bg font-semibold hover:shadow-lg transition-all"
          >
            S'inscrire
          </button>
        </form>

        <p class="text-xs text-peb-text2">
          Nous respectons votre vie privée. Désinscription facile à tout moment.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    label="Besoin d'un certificat?"
    title="Commencez maintenant"
    subtitle="Contactez-moi pour un audit PEB complet et un certificat agréé. Réponse sous 24 heures."
    primaryHref="/contact/"
    primaryText="Prendre rendez-vous"
    secondaryHref="/tarifs-peb-bruxelles/"
    secondaryText="Voir les tarifs"
  />
</PageLayout>
