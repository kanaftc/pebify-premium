---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CommuneLinks from '../../components/sections/CommuneLinks.astro';

const faqItems = [
  {
    question: 'Comment certifier une villa auprès de la Forêt de Soignes?',
    answer: 'Les villas de Watermael-Boitsfort, même auprès de la Forêt de Soignes, se certifient de manière standard. La proximité de la forêt n\'affecte pas la certification. Je maîtrise l\'architecture typique de cette commune verdoyante.'
  },
  {
    question: 'Quel profil énergétique pour les villas de Watermael?',
    answer: 'Les villas de Watermael-Boitsfort obtiennent généralement C à F. L\'environnement naturel reflète souvent des propriétés bien entretenues offrant bon potentiel d\'amélioration.'
  },
  {
    question: 'Quel tarif pour une grande villa à Watermael?',
    answer: 'Pour les villas de Watermael-Boitsfort, mon tarif est 249€ minimum. Contactez-moi pour les propriétés exceptionnelles. Les délais sont rapides dans cette commune.'
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PEBify - Certificat PEB Watermael-Boitsfort",
  "description": "Expert en certification PEB agréé à Watermael-Boitsfort (1170)",
  "url": "https://pebify.be/certificat-peb-watermael-boitsfort/",
  "areaServed": { "@type": "City", "name": "Watermael-Boitsfort", "postalCode": "1170" },
  "priceRange": "€€€"
};
---

<PageLayout
  title="Certificat PEB Watermael-Boitsfort (1170) — Dès 189€ | Certificateur Agréé"
  description="Expert en certification PEB à Watermael-Boitsfort (1170). Spécialiste des villas résidentielles et propriétés de prestige. Certificats énergétiques agréés complets."
  breadcrumb={[{ label: 'Certificat PEB Watermael-Boitsfort', href: '/certificat-peb-watermael-boitsfort/' }]}
  heroLabel="Certification PEB"
  heroTitle="Certificat PEB à Watermael-Boitsfort"
  heroSubtitle="Spécialiste de la certification énergétique à Watermael-Boitsfort (1170). Expert en villas résidentielles et propriétés de prestige."
  canonical="https://pebify.be/certificat-peb-watermael-boitsfort/"
  schemaJson={jsonLd}
>
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-6 text-peb-text">
          Certificat PEB à <span class="gradient-text-cyan">Watermael-Boitsfort</span>
        </h2>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
