---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CommuneLinks from '../../components/sections/CommuneLinks.astro';

const faqItems = [
  {
    question: 'La Basilique Nationale domine-t-elle les propriétés alentours?',
    answer: 'La Basilique est un landmark iconique mais n\'affecte pas la certification PEB. J\'évalue la performance énergétique indépendamment de l\'environnement. Les propriétés près de la Basilique sont comme les autres.'
  },
  {
    question: 'Quel profil énergétique pour les maisons de Koekelberg?',
    answer: 'Les petites maisons et immeubles de Koekelberg obtiennent généralement D à F. Les opportunités d\'amélioration sont significatives, notamment pour l\'isolation et les vitrages.'
  },
  {
    question: 'Quel tarif pour une petite maison à Koekelberg?',
    answer: 'Pour une petite maison, mon tarif est 189€ incluant visite et rapport détaillé. Contactez-moi pour les multi-propriétés ou immeubles collectifs.'
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PEBify - Certificat PEB Koekelberg",
  "description": "Expert en certification PEB agréé à Koekelberg (1081)",
  "url": "https://pebify.be/certificat-peb-koekelberg/",
  "areaServed": { "@type": "City", "name": "Koekelberg", "postalCode": "1081" },
  "priceRange": "€€"
};
---

<PageLayout
  title="Certificat PEB Koekelberg (1081) — Dès 189€ | Certificateur Agréé"
  description="Expert en certification PEB à Koekelberg (1081). Certificats énergétiques agréés pour petites maisons et immeubles collectifs. Service transparent et fiable."
  breadcrumb={[{ label: 'Certificat PEB Koekelberg', href: '/certificat-peb-koekelberg/' }]}
  heroLabel="Certification PEB"
  heroTitle="Certificat PEB à Koekelberg"
  heroSubtitle="Certificateur agréé pour vos propriétés koekelbergoises. Expert en petites maisons et immeubles collectifs."
  canonical="https://pebify.be/certificat-peb-koekelberg/"
  schemaJson={jsonLd}
>
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-6 text-peb-text">
          Certificat PEB à <span class="gradient-text-cyan">Koekelberg</span>
        </h2>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Koekelberg, petite commune du nord-ouest bruxellois, captive par son patrimoine architectural remarquable et son atmosphère unique. La Basilique Nationale, monument iconique du paysage bruxellois, domine le quartier et reflète l'identité particulière de Koekelberg. Avec environ 25 000 habitants, elle se caractérise par un habitat résidentiel classique combinant petites maisons de quartier et petits immeubles collectifs.
        </p>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Je certifie régulièrement les propriétés koekelbergoises avec expertise spécialisée. Les maisons typiques de Koekelberg, souvent du début du XXe siècle, présentent d'excellentes perspectives de rénovation énergétique.
        </p>
      </div>

      <div class="bg-peb-surface border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Propriétés à Koekelberg
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Petites maisons</p>
              <p class="text-peb-text2 text-sm">Certification de maisons de quartier typiques.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Immeubles collectifs</p>
              <p class="text-peb-text2 text-sm">Certification d'immeubles résidentiels petits.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Petits logements</p>
              <p class="text-peb-text2 text-sm">Certification de structures d'habitation compactes.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Habitats urbains</p>
              <p class="text-peb-text2 text-sm">Certification de propriétés urbaines variées.</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Profil énergétique
        </h3>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Les propriétés koekelbergoises obtiennent généralement D à F. L'amélioration de l'isolation, des vitrages et du chauffage offre les meilleurs résultats.
        </p>
      </div>

      <div class="bg-peb-card border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Services
        </h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Certificat PEB</h4>
            <p class="text-peb-text2 text-sm">Certification officielle pour tous types.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Audit énergétique</h4>
            <p class="text-peb-text2 text-sm">Analyse détaillée avec recommandations.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Rapport complet</h4>
            <p class="text-peb-text2 text-sm">Documentation stratégique.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Consultation</h4>
            <p class="text-peb-text2 text-sm">Expertise spécialisée.</p>
          </div>
        </div>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Tarification
        </h3>
        <div class="grid sm:grid-cols-3 gap-4 mb-6">
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Petit bien</p>
            <p class="text-3xl font-bold text-peb-cyan">189€</p>
          </div>
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Duplex</p>
            <p class="text-3xl font-bold text-peb-cyan">219€</p>
          </div>
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Maison</p>
            <p class="text-3xl font-bold text-peb-cyan">249€</p>
          </div>
        </div>
        <p class="text-peb-text2 mb-4">
          <a href="/contact/" class="text-peb-cyan hover:text-peb-green font-medium transition-colors">Contactez-moi</a> pour votre devis.
        </p>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Ressources
        </h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/guide-peb/definition/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Qu'est-ce que le PEB?</p>
            <p class="text-sm text-peb-text2">Comprendre.</p>
          </a>
          <a href="/guide-peb/ameliorer-score/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Améliorer votre score</p>
            <p class="text-sm text-peb-text2">Recommandations.</p>
          </a>
          <a href="/guide-peb/echelle-classes/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Classes énergétiques</p>
            <p class="text-sm text-peb-text2">A++ à G.</p>
          </a>
          <a href="/guide-peb/primes/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Aides rénovation</p>
            <p class="text-sm text-peb-text2">Primes 2026.</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} />

  <CTA
    title="Certificat PEB à Koekelberg"
    subtitle="Contactez-moi pour votre certification énergétique."
    primaryHref="/contact/"
    primaryText="Demander un devis"
    secondaryHref="/guide-peb/"
    secondaryText="En savoir plus"
  />

  <CommuneLinks />
</PageLayout>
