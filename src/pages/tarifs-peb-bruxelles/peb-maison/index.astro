---
import PageLayout from '../../../layouts/PageLayout.astro';
import CTA from '../../../components/sections/CTA.astro';
import Card from '../../../components/ui/Card.astro';
import Badge from '../../../components/ui/Badge.astro';

const breadcrumb = [
  { label: 'Tarifs', href: '/tarifs-peb-bruxelles/' },
  { label: 'PEB Maison', href: '/tarifs-peb-bruxelles/peb-maison/' },
];

const schemaJson = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Certificat PEB Maison Bruxelles',
  provider: {
    '@type': 'LocalBusiness',
    name: 'PEBify',
    url: 'https://pebify.be',
  },
  areaServed: {
    '@type': 'City',
    name: 'Bruxelles',
  },
  offers: {
    '@type': 'Offer',
    name: 'Certificat PEB Maison',
    price: '235',
    priceCurrency: 'EUR',
    url: 'https://pebify.be/tarifs-peb-bruxelles/peb-maison/',
  },
};
---

<PageLayout
  title="PEB Maison Bruxelles | Prix 235€ TTC | PEBify"
  description="Certificat PEB maison Bruxelles : 235€ TTC. Audit 1h-2h. Maison de rangée, 3 façades, 4 façades. Prix transparent."
  canonical="https://pebify.be/tarifs-peb-bruxelles/peb-maison/"
  breadcrumb={breadcrumb}
  heroLabel="Audit énergétique complet"
  heroTitle="PEB Maison Bruxelles"
  heroSubtitle="Certificat PEB pour maisons unifamiliales à Bruxelles. À partir de 235€ TTC. Audit complet 1h - 2h."
  schemaJson={schemaJson}
>
  <!-- Price Section -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <div class="inline-flex items-center space-x-2 mb-6">
          <div class="w-2 h-2 rounded-full bg-peb-cyan animate-pulse-dot" />
          <span class="text-sm font-medium text-peb-cyan uppercase tracking-wider">Tarif transparent</span>
        </div>
        <div class="text-6xl md:text-7xl font-display font-bold text-peb-cyan mb-4">235€</div>
        <p class="text-xl text-peb-text2">TTC, tout compris, sans surprise</p>
      </div>

      <div class="bg-peb-card border border-peb-border rounded-xl p-8 space-y-6 reveal">
        <h3 class="text-xl font-display font-bold text-peb-text">Ce qui est inclus :</h3>

        <div class="space-y-4">
          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Visite complète multi-zones</p>
              <p class="text-peb-text2">1h - 2h. Inspection intérieure ET extérieure. Tous les niveaux et zones thermiques.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Audit énergétique exhaustif</p>
              <p class="text-peb-text2">Tous systèmes : chauffage, eau chaude, ventilation, isolation, fenêtres, sources d'énergie.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Certificat officiel PEB</p>
              <p class="text-peb-text2">Enregistré légalement, valide 10 ans, reconnu partout en Belgique.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Rapport détaillé complet</p>
              <p class="text-peb-text2">Classe PEB, consommation, graphiques, et analyse zone par zone.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Support post-audit & conseils</p>
              <p class="text-peb-text2">Explications du rapport, recommandations d'amélioration, support dossiers primes.</p>
            </div>
          </div>
        </div>

        <div class="bg-peb-bg border border-peb-border rounded-lg p-4 text-center mt-6">
          <p class="text-sm text-peb-text2 mb-2">Aucun frais caché. TVA 21% incluse.</p>
          <p class="font-semibold text-peb-text">Prix final = 235€ exactement</p>
        </div>
      </div>
    </div>
  </section>

  <!-- House Types -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-surface border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Types de <span class="gradient-text-cyan">maisons</span>
        </h2>
        <p class="text-lg text-peb-text2">
          Ce tarif s'applique à toutes les maisons unifamiliales
        </p>
      </div>

      <div class="space-y-6 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-2xl p-8 space-y-4">
          <div class="flex items-start gap-4">
            <div class="text-5xl">🏠</div>
            <div class="flex-1">
              <h3 class="text-xl font-display font-bold text-peb-text mb-2">Maison de rangée (mitoyenne)</h3>
              <p class="text-peb-text2 mb-4">
                Maison avec une ou deux mitoyennetés. Très communes à Bruxelles. Avantage : murs mitoyens = moins de déperdition.
              </p>
              <div class="space-y-2 text-sm text-peb-text2">
                <p>• Surface type : 120-250m²</p>
                <p>• Façades : 2-3 façades externes</p>
                <p>• Durée audit : 1h - 1h30</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-2xl p-8 space-y-4">
          <div class="flex items-start gap-4">
            <div class="text-5xl">🏡</div>
            <div class="flex-1">
              <h3 class="text-xl font-display font-bold text-peb-text mb-2">Maison 3 façades</h3>
              <p class="text-peb-text2 mb-4">
                Maison d'angle ou semi-détachée avec 3 façades. Déperditions modérées. Très appréciées pour l'espace et la lumière.
              </p>
              <div class="space-y-2 text-sm text-peb-text2">
                <p>• Surface type : 150-300m²</p>
                <p>• Façades : 3 façades externes</p>
                <p>• Durée audit : 1h15 - 1h45</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-2xl p-8 space-y-4">
          <div class="flex items-start gap-4">
            <div class="text-5xl">🏘️</div>
            <div class="flex-1">
              <h3 class="text-xl font-display font-bold text-peb-text mb-2">Maison 4 façades (détachée)</h3>
              <p class="text-peb-text2 mb-4">
                Maison complètement détachée, 4 façades. Magnifique mais thermiquement plus exigeante (plus de surface en contact).
              </p>
              <div class="space-y-2 text-sm text-peb-text2">
                <p>• Surface type : 200-400m²</p>
                <p>• Façades : 4 façades externes</p>
                <p>• Durée audit : 1h30 - 2h</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-2xl p-8 space-y-4">
          <div class="flex items-start gap-4">
            <div class="text-5xl">🏰</div>
            <div class="flex-1">
              <h3 class="text-xl font-display font-bold text-peb-text mb-2">Maison avec extensions (garage, véranda)</h3>
              <p class="text-peb-text2 mb-4">
                Maison + garage + véranda + pool house = analyse multi-zones. Complexité augmente. Audit détaillé nécessaire.
              </p>
              <div class="space-y-2 text-sm text-peb-text2">
                <p>• Surface totale : 250-500m²</p>
                <p>• Zones multiples avec transitions thermiques</p>
                <p>• Durée audit : 1h45 - 2h30</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 bg-orange-500/10 border border-orange-500/20 rounded-xl p-6 reveal">
        <p class="font-semibold text-orange-600 mb-2">💡 Note importante:</p>
        <p class="text-peb-text2">
          Plus la maison a de façades, plus de déperditions thermiques. Une 4 façades perd environ 30% plus de chaleur qu'une 2 façades. C'est normal et pris en compte dans le PEB.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Houses Differ -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Pourquoi l'audit maison est plus <span class="gradient-text-cyan">complexe</span>?
        </h2>
      </div>

      <div class="space-y-6 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">📐</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Géométrie complexe</h3>
            <p class="text-peb-text2">
              Maisons ont plusieurs façades, angles, toitures pentes. Calcul des surfaces et orientation solaire plus complexe.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">🌡️</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Zones thermiques multiples</h3>
            <p class="text-peb-text2">
              Cave, rez, étages, greniers, annexes = 5+ zones. Transitions thermiques complexes à modéliser.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">🔍</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Inspection extérieure complète</h3>
            <p class="text-peb-text2">
              Toiture, gouttières, fondations, murs, fenêtres... Maison nécessite inspection aussi à l'extérieur.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">⚡</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Systèmes énergétiques diversifiés</h3>
            <p class="text-peb-text2">
              Chauffage central, radiateurs, plancher chauffant, eau chaude indépendante, panneaux solaires... Analyse poussée.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">💼</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Expertise plus élevée requise</h3>
            <p class="text-peb-text2">
              Audit maison demande plus de temps, d'expertise, et d'analyse. C'est pourquoi le tarif est légèrement supérieur à appartement.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Improvements -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-surface border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Actions recommandées <span class="gradient-text-cyan">pour maisons</span>
        </h2>
      </div>

      <div class="space-y-4 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <div class="flex items-start gap-4">
            <Badge variant="cyan" text="1ère" />
            <div class="flex-1">
              <h3 class="font-semibold text-peb-text mb-2">Isolation toiture/combles</h3>
              <p class="text-peb-text2 text-sm">
                Perte majeure par le toit (25%). Impact -15-20%. Coût 1500€-4000€. Très éligible aux primes.
              </p>
            </div>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <div class="flex items-start gap-4">
            <Badge variant="blue" text="2ème" />
            <div class="flex-1">
              <h3 class="font-semibold text-peb-text mb-2">Pompe à chaleur air-air/air-eau</h3>
              <p class="text-peb-text2 text-sm">
                Remplace chauffage gaz. Impact -20-30%. Coût 8000€-15000€. Primes 40-50%.
              </p>
            </div>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <div class="flex items-start gap-4">
            <Badge variant="green" text="3ème" />
            <div class="flex-1">
              <h3 class="font-semibold text-peb-text mb-2">Fenêtres triple vitrage</h3>
              <p class="text-peb-text2 text-sm">
                4 façades = beaucoup de fenêtres. Impact -10-15%. Coût 5000€-10000€. Primes partielles.
              </p>
            </div>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <div class="flex items-start gap-4">
            <Badge variant="cyan" text="4ème" />
            <div class="flex-1">
              <h3 class="font-semibold text-peb-text mb-2">Isolation murs (intérieur ou extérieur)</h3>
              <p class="text-peb-text2 text-sm">
                Action majeure. Coûteuse 5000€-20000€. Impact -20-30%. Primes complètes. À planifier avec soin.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline & Process -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Processus d'<span class="gradient-text-cyan">audit maison</span>
        </h2>
      </div>

      <div class="space-y-4 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-peb-cyan/20 flex items-center justify-center">
            <span class="text-peb-cyan font-bold">1</span>
          </div>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Prise de contact</h3>
            <p class="text-peb-text2 text-sm">
              RDV dans 2-3 jours. Je vous pose questions : année construction, chauffage, state général.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-peb-cyan/20 flex items-center justify-center">
            <span class="text-peb-cyan font-bold">2</span>
          </div>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Audit sur site (1h - 2h)</h3>
            <p class="text-peb-text2 text-sm">
              Inspection intérieure + extérieure complète. Mesures, photos, contrôles détaillés.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-peb-cyan/20 flex items-center justify-center">
            <span class="text-peb-cyan font-bold">3</span>
          </div>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Analyse & modélisation</h3>
            <p class="text-peb-text2 text-sm">
              Calcul consommation énergétique, classe PEB, graphiques. Rapport détaillé rédigé.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-peb-cyan/20 flex items-center justify-center">
            <span class="text-peb-cyan font-bold">4</span>
          </div>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Livraison (3-5 jours)</h3>
            <p class="text-peb-text2 text-sm">
              Certificat officiel PEB + rapport complet par email. Valide 10 ans. Prêt pour vente/location/primes.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-surface border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Questions <span class="gradient-text-cyan">fréquentes maisons</span>
        </h2>
      </div>

      <div class="space-y-4 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Ma maison est vieille (1950s). Quelle classe attendu?</h3>
          <p class="text-peb-text2 text-sm">
            Probablement classe D-E si pas rénovée. C'est normal pour maisons anciennes. Améliorations possibles.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Audit obligatoire pour vente?</h3>
          <p class="text-peb-text2 text-sm">
            OUI. Avant signature chez notaire. Responsable = vendeur. Amende 1000€-5000€ en cas absence.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">4 façades = plus mauvaise classe?</h3>
          <p class="text-peb-text2 text-sm">
            Oui, généralement 1-2 points de classe inférieure. Mais excellente maison pour qualité de vie.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Grenier non aménagé, compte-t-il?</h3>
          <p class="text-peb-text2 text-sm">
            Oui. Même non habité, c'est une zone thermique. Isolation toiture grenier = action prioritaire.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Panneaux solaires, quel impact PEB?</h3>
          <p class="text-peb-text2 text-sm">
            Positif! Réduisent consommation énergétique. Classe PEB meilleure. Très bon pour valeur.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    label="Prêt pour l'audit complet de votre maison?"
    title="Prenez rendez-vous maintenant"
    subtitle="235€, tout compris. Audit 1h-2h. Rapport détaillé et certificat en 3-5 jours. Support post-audit inclus."
    primaryHref="/contact/"
    primaryText="Prendre rendez-vous"
    secondaryHref="/tarifs-peb-bruxelles/"
    secondaryText="Voir tous les tarifs"
  />
</PageLayout>
