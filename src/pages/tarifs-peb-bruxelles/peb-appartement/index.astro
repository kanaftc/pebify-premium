---
import PageLayout from '../../../layouts/PageLayout.astro';
import CTA from '../../../components/sections/CTA.astro';
import Card from '../../../components/ui/Card.astro';
import Badge from '../../../components/ui/Badge.astro';
import Button from '../../../components/ui/Button.astro';

const breadcrumb = [
  { label: 'Tarifs', href: '/tarifs-peb-bruxelles/' },
  { label: 'PEB Appartement', href: '/tarifs-peb-bruxelles/peb-appartement/' },
];

const schemaJson = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Certificat PEB Appartement Bruxelles',
  provider: {
    '@type': 'LocalBusiness',
    name: 'PEBify',
    url: 'https://pebify.be',
  },
  areaServed: {
    '@type': 'City',
    name: 'Bruxelles',
  },
  offers: {
    '@type': 'Offer',
    name: 'Certificat PEB Appartement',
    price: '189',
    priceCurrency: 'EUR',
    url: 'https://pebify.be/tarifs-peb-bruxelles/peb-appartement/',
  },
};
---

<PageLayout
  title="PEB Appartement Bruxelles | Prix 189€ TTC | PEBify"
  description="Certificat PEB appartement à Bruxelles : 189€ TTC, studio à T3. Audit complet, rapport détaillé, certificat agréé. Durée 30-45 min."
  canonical="https://pebify.be/tarifs-peb-bruxelles/peb-appartement/"
  breadcrumb={breadcrumb}
  heroLabel="Audit énergétique"
  heroTitle="PEB Appartement Bruxelles"
  heroSubtitle="Certificat PEB pour studios, T2, T3 à Bruxelles. À partir de 189€ TTC. Service complet en 30-45 minutes."
  schemaJson={schemaJson}
>
  <!-- Price Section -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <div class="inline-flex items-center space-x-2 mb-6">
          <div class="w-2 h-2 rounded-full bg-peb-cyan animate-pulse-dot" />
          <span class="text-sm font-medium text-peb-cyan uppercase tracking-wider">Tarif transparent</span>
        </div>
        <div class="text-6xl md:text-7xl font-display font-bold text-peb-cyan mb-4 reveal">189€</div>
        <p class="text-xl text-peb-text2">TTC, tout compris, sans surprise</p>
      </div>

      <div class="bg-peb-card border border-peb-border rounded-xl p-8 space-y-6 reveal">
        <h3 class="text-xl font-display font-bold text-peb-text">Ce qui est inclus :</h3>

        <div class="space-y-4">
          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Visite sur site complète</p>
              <p class="text-peb-text2">30-45 minutes. Inspection de tous les éléments énergétiques.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Audit énergétique détaillé</p>
              <p class="text-peb-text2">Analyse de l'isolation, chauffage, fenêtres, ventilation.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Certificat officiel PEB</p>
              <p class="text-peb-text2">Enregistré légalement, valide 10 ans, reconnu partout.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Rapport énergétique complet</p>
              <p class="text-peb-text2">Classe PEB, consommation estimée, et détails techniques.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">✓</span>
            <div>
              <p class="font-semibold text-peb-text mb-1">Délai rapide</p>
              <p class="text-peb-text2">Certificat délivré en 3-5 jours ouvrables.</p>
            </div>
          </div>
        </div>

        <div class="bg-peb-bg border border-peb-border rounded-lg p-4 text-center mt-6">
          <p class="text-sm text-peb-text2 mb-2">Aucun frais caché. TVA 21% incluse.</p>
          <p class="font-semibold text-peb-text">Prix final = 189€ exactement</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Apartment Types -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-surface border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Types d'<span class="gradient-text-cyan">appartements</span>
        </h2>
        <p class="text-lg text-peb-text2">
          Ce tarif s'applique à tous les types d'appartements
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal-stagger">
        <Card hover={true}>
          <div class="space-y-4">
            <div class="text-5xl">🔑</div>
            <h3 class="text-xl font-display font-bold text-peb-text">Studio</h3>
            <p class="text-peb-text2">Jusqu'à 50m². Petit appt idéal pour location courte durée.</p>
            <p class="text-sm text-peb-cyan font-semibold">Durée audit: 20-25 min</p>
          </div>
        </Card>

        <Card hover={true}>
          <div class="space-y-4">
            <div class="text-5xl">🏠</div>
            <h3 class="text-xl font-display font-bold text-peb-text">T2 (2 pièces)</h3>
            <p class="text-peb-text2">50-80m². Petit/moyen appartement pour couple ou petit bureau.</p>
            <p class="text-sm text-peb-cyan font-semibold">Durée audit: 25-30 min</p>
          </div>
        </Card>

        <Card hover={true}>
          <div class="space-y-4">
            <div class="text-5xl">🏘️</div>
            <h3 class="text-xl font-display font-bold text-peb-text">T3 (3 pièces)</h3>
            <p class="text-peb-text2">80-100m². Idéal famille petite ou location investisseur.</p>
            <p class="text-sm text-peb-cyan font-semibold">Durée audit: 35-45 min</p>
          </div>
        </Card>

        <Card hover={true}>
          <div class="space-y-4">
            <div class="text-5xl">✨</div>
            <h3 class="text-xl font-display font-bold text-peb-text">Penthouse/Loft</h3>
            <p class="text-peb-text2">Configurations spéciales. Tarif 189€ s'applique aussi.</p>
            <p class="text-sm text-peb-cyan font-semibold">Audit selon configuration</p>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Why Apartments -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Pourquoi le PEB est <span class="gradient-text-cyan">important</span> pour les appartements?
        </h2>
      </div>

      <div class="space-y-6 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">📋</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Obligation légale stricte</h3>
            <p class="text-peb-text2">
              Toute vente ou location d'appartement à Bruxelles nécessite un certificat PEB avant signature. Absence = amende jusqu'à 5000€.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">💰</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Impact sur la valeur</h3>
            <p class="text-peb-text2">
              Un appartement classe A se vend/loue 5-10% plus cher qu'un classe D. Le PEB influence fortement les décisions d'achat.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">🔍</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Transparence pour acheteurs/locataires</h3>
            <p class="text-peb-text2">
              Le PEB affiche votre classe énergétique. Les acheteurs/locataires modernes le demandent systématiquement avant engagement.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl flex-shrink-0">📊</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-2">Factures énergétiques</h3>
            <p class="text-peb-text2">
              Un appartement bien isolé (classe A/B) réduit les factures chauffage de 40-50%. Important pour locataires et propriétaires.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-surface border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Processus <span class="gradient-text-cyan">détail</span>
        </h2>
      </div>

      <div class="space-y-4 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-peb-cyan/20 flex items-center justify-center">
            <span class="text-peb-cyan font-bold">1</span>
          </div>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Contacter & prendre RDV</h3>
            <p class="text-peb-text2">
              Par téléphone, email ou formulaire. Je vous proposerai des créneaux disponibles dans les 2-3 jours.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-peb-cyan/20 flex items-center justify-center">
            <span class="text-peb-cyan font-bold">2</span>
          </div>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Visite sur site (30-45 min)</h3>
            <p class="text-peb-text2">
              Chez vous. J'inspecte tous les éléments : isolation, chauffage, fenêtres, ventilation. Vous restez libre de vos affaires.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-peb-cyan/20 flex items-center justify-center">
            <span class="text-peb-cyan font-bold">3</span>
          </div>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Analyse & rapport</h3>
            <p class="text-peb-text2">
              Je traite les données, calcule votre classe PEB, et rédige un rapport énergétique complet.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-peb-cyan/20 flex items-center justify-center">
            <span class="text-peb-cyan font-bold">4</span>
          </div>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Certificat livré (3-5 jours)</h3>
            <p class="text-peb-text2">
              Document officiel par email. Valide légalement 10 ans. Prêt pour vente, location, ou améliorations.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Specific -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          FAQ <span class="gradient-text-cyan">Appartements</span>
        </h2>
      </div>

      <div class="space-y-4 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Je loue mon appart, qui doit payer le PEB?</h3>
          <p class="text-peb-text2">
            Vous (propriétaire) devez le payer avant signature du bail. C'est votre responsabilité légale.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Et si j'ai déjà un ancien PEB?</h3>
          <p class="text-peb-text2">
            S'il date de moins de 10 ans, il est valide. Au-delà, vous devez le refaire. Vérifiez la date.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Puis-je améliorer mon appartement après le PEB?</h3>
          <p class="text-peb-text2">
            Bien sûr! Le PEB vous identifie les améliorations prioritaires. Isolation fenêtres, chauffage, ventilation...
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Mon immeuble est vieux. C'est grave?</h3>
          <p class="text-peb-text2">
            Pas nécessairement. Les anciens immeubles sont souvent classe D/E, mais c'est gérable. Primes disponibles pour améliorer.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6">
          <h3 class="font-semibold text-peb-text mb-2">Je vends vite, urgence possible?</h3>
          <p class="text-peb-text2">
            Oui. Contactez-moi rapidement. Je peux souvent faire l'audit en 24-48h et livrer en 2-3 jours.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA
    label="Prêt pour votre audit?"
    title="Prenez rendez-vous maintenant"
    subtitle="189€, tout compris. Visite à votre convenance dans les 2-3 jours. Certificat en 3-5 jours."
    primaryHref="/contact/"
    primaryText="Prendre rendez-vous"
    secondaryHref="/tarifs-peb-bruxelles/"
    secondaryText="Voir tous les tarifs"
  />
</PageLayout>
