---
import PageLayout from '../../layouts/PageLayout.astro';
import StatsStrip from '../../components/sections/StatsStrip.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CTA from '../../components/sections/CTA.astro';
import CommuneLinks from '../../components/sections/CommuneLinks.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import { pricingTiers, addOns, faqPricing } from '../../data/pricing';
import { siteConfig } from '../../data/site';

const schemaJson = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Certificat PEB Bruxelles',
  provider: {
    '@type': 'LocalBusiness',
    name: 'PEBify',
    url: 'https://pebify.be',
  },
  areaServed: {
    '@type': 'City',
    name: 'Bruxelles',
  },
  offers: pricingTiers
    .filter((tier) => typeof tier.price === 'number')
    .map((tier) => ({
      '@type': 'Offer',
      name: tier.name,
      price: tier.price,
      priceCurrency: tier.currency,
      url: 'https://pebify.be/tarifs-peb-bruxelles/',
    })),
};

const breadcrumb = [
  { label: 'Tarifs', href: '/tarifs-peb-bruxelles/' },
];
---

<PageLayout
  title="Tarifs Certificat PEB Bruxelles | Prix transparent"
  description="Prix certificat PEB à Bruxelles: 189€ appartement, 249€ maison, 219€ duplex. Devis gratuit, sans frais cachés. Agréé Région bruxelloise."
  canonical="https://pebify.be/tarifs-peb-bruxelles/"
  breadcrumb={breadcrumb}
  heroLabel="Tarification transparente"
  heroTitle="Nos tarifs PEB à Bruxelles"
  heroSubtitle="Prix clairs, tout compris, sans surprise. Agréé Région bruxelloise avec certificats valides 10 ans."
  schemaJson={schemaJson}
>
  <!-- Type Selector Interactive Section -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Quel type de bien possédez-vous?
        </h2>
        <p class="text-lg text-peb-text2">
          Sélectionnez votre type de propriété pour voir mes tarifs exacts et les détails de mes services.
        </p>
      </div>

      <!-- Pricing Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal-stagger">
        <!-- Apartment -->
        <Card hover={true}>
          <div class="space-y-6 text-center">
            <div class="text-5xl">🏠</div>
            <div>
              <h3 class="text-2xl font-display font-bold text-peb-text mb-2">
                Appartement
              </h3>
              <p class="text-sm text-peb-text2">Studio à T3</p>
            </div>

            <div class="bg-peb-bg border border-peb-border rounded-lg p-6">
              <div class="text-5xl font-display font-bold text-peb-cyan mb-1">
                189
                <span class="text-2xl">€</span>
              </div>
              <p class="text-sm text-peb-text2">TTC tout compris</p>
            </div>

            <ul class="space-y-3 text-left text-sm text-peb-text2">
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Ma visite complète</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Audit énergétique</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Certificat officiel</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Validité 10 ans</span>
              </li>
            </ul>

            <Button href="/contact/" variant="primary" size="lg" class="w-full">
              Prendre rendez-vous
            </Button>
          </div>
        </Card>

        <!-- Duplex -->
        <Card hover={true}>
          <div class="space-y-6 text-center">
            <div class="text-5xl">🏘️</div>
            <div>
              <h3 class="text-2xl font-display font-bold text-peb-text mb-2">
                Duplex
              </h3>
              <p class="text-sm text-peb-text2">Maison mitoyenne</p>
            </div>

            <div class="bg-peb-bg border border-peb-border rounded-lg p-6">
              <div class="text-5xl font-display font-bold text-peb-cyan mb-1">
                219
                <span class="text-2xl">€</span>
              </div>
              <p class="text-sm text-peb-text2">TTC tout compris</p>
            </div>

            <ul class="space-y-3 text-left text-sm text-peb-text2">
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Ma visite complète</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Analyse 2 niveaux</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Certificat officiel</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Mon support après</span>
              </li>
            </ul>

            <Button href="/contact/" variant="primary" size="lg" class="w-full">
              Prendre rendez-vous
            </Button>
          </div>
        </Card>

        <!-- House (Popular) -->
        <Card hover={true}>
          <div class="relative space-y-6 text-center">
            <Badge variant="cyan" text="Plus populaire" />
            <div class="text-5xl">🏡</div>
            <div>
              <h3 class="text-2xl font-display font-bold text-peb-text mb-2">
                Maison
              </h3>
              <p class="text-sm text-peb-text2">Maison unifamiliale</p>
            </div>

            <div class="bg-peb-bg border border-peb-border rounded-lg p-6">
              <div class="text-5xl font-display font-bold text-peb-cyan mb-1">
                249
                <span class="text-2xl">€</span>
              </div>
              <p class="text-sm text-peb-text2">TTC tout compris</p>
            </div>

            <ul class="space-y-3 text-left text-sm text-peb-text2">
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Ma visite complète</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Analyse multi-zones</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Mon support après</span>
              </li>
              <li class="flex gap-2">
                <span class="text-peb-cyan">✓</span>
                <span>Validité 10 ans</span>
              </li>
            </ul>

            <Button href="/contact/" variant="primary" size="lg" class="w-full">
              Prendre rendez-vous
            </Button>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-surface border-b border-peb-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Ce qui est <span class="gradient-text-cyan">inclus</span>
        </h2>
        <p class="text-lg text-peb-text2">
          Nos tarifs incluent tout ce dont vous avez besoin.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal-stagger">
        <div class="space-y-4">
          <h3 class="text-xl font-display font-bold text-peb-text">Service complet</h3>
          <ul class="space-y-3">
            <li class="flex gap-3">
              <span class="text-peb-cyan text-xl">✓</span>
              <div>
                <div class="font-semibold text-peb-text">Visite sur site</div>
                <p class="text-sm text-peb-text2">1-2 heures selon type de bien</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-peb-cyan text-xl">✓</span>
              <div>
                <div class="font-semibold text-peb-text">Audit énergétique</div>
                <p class="text-sm text-peb-text2">Analyse détaillée de tous systèmes</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-peb-cyan text-xl">✓</span>
              <div>
                <div class="font-semibold text-peb-text">Rapport complet</div>
                <p class="text-sm text-peb-text2">Documentation officielle détaillée</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="space-y-4">
          <h3 class="text-xl font-display font-bold text-peb-text">Garanties incluses</h3>
          <ul class="space-y-3">
            <li class="flex gap-3">
              <span class="text-peb-cyan text-xl">✓</span>
              <div>
                <div class="font-semibold text-peb-text">Certificat officiel</div>
                <p class="text-sm text-peb-text2">Enregistrement légal garanti</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-peb-cyan text-xl">✓</span>
              <div>
                <div class="font-semibold text-peb-text">Validité 10 ans</div>
                <p class="text-sm text-peb-text2">Reconnu légalement et définitif</p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-peb-cyan text-xl">✓</span>
              <div>
                <div class="font-semibold text-peb-text">Aucun frais caché</div>
                <p class="text-sm text-peb-text2">Prix affiché = prix final TTC</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Price Calculation Section -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Comment est calculé votre <span class="gradient-text-cyan">prix</span>?
        </h2>
      </div>

      <div class="space-y-6 reveal">
        <div class="bg-peb-card border border-peb-border rounded-2xl p-8 space-y-4">
          <h3 class="font-display font-bold text-peb-text">1. Type de bien</h3>
          <p class="text-peb-text2">
            Mon tarif de base dépend si c'est un appartement (189€), un duplex (219€) ou une maison (249€). Chaque type demande une expertise différente.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-2xl p-8 space-y-4">
          <h3 class="font-display font-bold text-peb-text">2. Surface habitable</h3>
          <p class="text-peb-text2">
            La surface influence mon temps d'inspection et la complexité de l'audit. Ma calculatrice en ligne vous donne une estimation en temps réel.
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-2xl p-8 space-y-4">
          <h3 class="font-display font-bold text-peb-text">3. Services additionnels</h3>
          <p class="text-peb-text2">
            Vous pouvez ajouter thermographie (150€), test d'infiltrométrie (180€), ou un audit premium complet (549€ au lieu de tarif simple).
          </p>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-2xl p-8 space-y-4">
          <h3 class="font-display font-bold text-peb-text">4. Tarif final</h3>
          <p class="text-peb-text2">
            TVA incluse. Pas de frais d'enregistrement supplémentaire. Pas de frais cachés. Vous payez exactement ce que j'annonce.
          </p>
        </div>
      </div>

      <div class="mt-12 bg-peb-surface border border-peb-border rounded-2xl p-8 text-center reveal">
        <p class="text-peb-text2 mb-6">
          Vous voulez une estimation précise pour votre bien? Je vous prépare un devis détaillé gratuitement.
        </p>
        <Button href="/contact/" variant="primary" size="lg" hasArrow>
          Demander mon devis gratuit
        </Button>
      </div>
    </div>
  </section>

  <!-- Why Competitive Section -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-surface border-b border-peb-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Pourquoi nos tarifs sont <span class="gradient-text-cyan">compétitifs</span>?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal-stagger">
        <Card hover={true}>
          <div class="space-y-3">
            <div class="text-4xl">🎯</div>
            <h3 class="font-display font-bold text-peb-text">Je travaille en direct</h3>
            <p class="text-peb-text2">
              Je traite personnellement chaque dossier sans intermédiaires. Zéro commission, zéro surcoûts. Vous bénéficiez de mes tarifs directs.
            </p>
          </div>
        </Card>

        <Card hover={true}>
          <div class="space-y-3">
            <div class="text-4xl">⚡</div>
            <h3 class="font-display font-bold text-peb-text">Ma méthode optimisée</h3>
            <p class="text-peb-text2">
              Après plus de 14 ans d'expérience, j'ai affiné ma méthode pour être rapide et fiable. Moins de temps = moins de coûts = prix compétitifs.
            </p>
          </div>
        </Card>

        <Card hover={true}>
          <div class="space-y-3">
            <div class="text-4xl">💼</div>
            <h3 class="font-display font-bold text-peb-text">Je suis agréé officiellement</h3>
            <p class="text-peb-text2">
              Mon agrément Région bruxelloise est à jour. Je fais des audits qualitatifs qui limitent les reprises et les frais additionnels.
            </p>
          </div>
        </Card>

        <Card hover={true}>
          <div class="space-y-3">
            <div class="text-4xl">📊</div>
            <h3 class="font-display font-bold text-peb-text">Je suis transparent</h3>
            <p class="text-peb-text2">
              Aucun frais caché. Je vous cite précisément avant de commencer. Vous savez exactement ce que vous payez.
            </p>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- When Do You Need PEB Section -->
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg border-b border-peb-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-4">
          Quand avez-vous besoin d'un <span class="gradient-text-cyan">certificat PEB</span>?
        </h2>
      </div>

      <div class="space-y-4 reveal-stagger">
        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl">🏠</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Vente immobilière</h3>
            <p class="text-peb-text2">
              Obligatoire avant la conclusion. C'est au vendeur de le fournir, mais je peux l'établir rapidement pour régulariser.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl">🔑</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Location</h3>
            <p class="text-peb-text2">
              Obligatoire pour toute location de longue durée (> 6 mois) à Bruxelles. Je vous prépare le document légal incontournable.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl">🔨</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Rénovation</h3>
            <p class="text-peb-text2">
              Je recommande un audit avant rénovation pour établir un diagnostic énergétique et planifier les améliorations optimales.
            </p>
          </div>
        </div>

        <div class="bg-peb-card border border-peb-border rounded-xl p-6 flex gap-4">
          <span class="text-3xl">📋</span>
          <div>
            <h3 class="font-semibold text-peb-text mb-1">Audit énergétique</h3>
            <p class="text-peb-text2">
              Je vous aide à comprendre votre consommation énergétique et j'identifie les mesures de réduction les plus efficaces pour vous.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <CommuneLinks />

  <!-- FAQ -->
  {faqPricing.length > 0 && (
    <FAQ
      items={faqPricing.map((item) => ({
        question: item.question,
        answer: item.answer,
      }))}
    />
  )}

  <!-- CTA -->
  <CTA
    label="Prêt à connaître votre tarif exact?"
    title="Demandez mon devis gratuit"
    subtitle="Je vous réponds sous 24 heures. Aucun engagement. Tarif précis et détaillé."
    primaryHref="/contact/"
    primaryText="Prendre rendez-vous"
    secondaryHref="https://wa.me/32484630815"
    secondaryText="WhatsApp"
  />
</PageLayout>
