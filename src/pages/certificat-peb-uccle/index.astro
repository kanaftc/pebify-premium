---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CommuneLinks from '../../components/sections/CommuneLinks.astro';

const faqItems = [
  {
    question: 'Comment certifier une villa de prestige à Uccle?',
    answer: 'Les villas de prestige d\'Uccle sont ma spécialité. Je maîtrise parfaitement l\'architecture résidentielle haut de gamme de cette commune. Ma certification garantit une évaluation précise de votre propriété remarquable.'
  },
  {
    question: 'Quel profil énergétique pour les villas uccloise?',
    answer: 'Les villas d\'Uccle obtiennent généralement D à C selon leur date de construction et améliorations. La majorité offre un excellent potentiel d\'amélioration énergétique significative.'
  },
  {
    question: 'Quel tarif pour une grande villa à Uccle?',
    answer: 'Pour les villas de prestige à Uccle, je propose un tarif de 249€ minimum. Pour les propriétés exceptionnelles, contactez-moi pour un devis personnalisé reflétant la complexité.'
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PEBify - Certificat PEB Uccle",
  "description": "Expert en certification PEB agréé à Uccle (1180)",
  "url": "https://pebify.be/certificat-peb-uccle/",
  "areaServed": { "@type": "City", "name": "Uccle", "postalCode": "1180" },
  "priceRange": "€€€"
};
---

<PageLayout
  title="Certificat PEB Uccle (1180) — Dès 189€ | Certificateur Agréé"
  description="Expert en certification PEB à Uccle (1180). Spécialiste des villas de prestige et demeures bourgeoises. Certificats énergétiques agréés pour propriétés haut de gamme."
  breadcrumb={[{ label: 'Certificat PEB Uccle', href: '/certificat-peb-uccle/' }]}
  heroLabel="Certification PEB"
  heroTitle="Certificat PEB à Uccle"
  heroSubtitle="Spécialiste de la certification énergétique des villas de prestige uccloise. Expert en propriétés haut de gamme."
  canonical="https://pebify.be/certificat-peb-uccle/"
  schemaJson={jsonLd}
>
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-6 text-peb-text">
          Certificat PEB à <span class="gradient-text-cyan">Uccle</span>
        </h2>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Uccle, commune du sud-ouest bruxellois, offre un cadre résidentiel haut de gamme et un environnement naturel préservé. Avec plus de 84 000 habitants, elle concentre un habitat résidentiel de prestige dominé par des villas particulières et des demeures spacieuses. Le Parc de Wolvendael et la Forêt de Soignes constituent le cœur naturel remarquable d'Uccle.
        </p>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Je suis spécialisé dans la certification des villas de prestige et demeures spacieuses d'Uccle. Mon expertise approfondie me permet d'évaluer précisément ces propriétés remarquables avec exactitude et respect de leurs spécificités.
        </p>
      </div>

      <div class="bg-peb-surface border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Propriétés à Uccle
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Villas de prestige</p>
              <p class="text-peb-text2 text-sm">Certification de villas spacieuses et demeures exceptionnelles.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Demeures bourgeoises</p>
              <p class="text-peb-text2 text-sm">Certification de propriétés bourgeoises classiques.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Propriétés spacieuses</p>
              <p class="text-peb-text2 text-sm">Certification de maisons spacieuses de standing.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Maisons de prestige</p>
              <p class="text-peb-text2 text-sm">Certification de propriétés d\'exception.</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Profil énergétique
        </h3>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Uccle présente un portefeuille énergétique de qualité. Les villas obtiennent généralement C à F selon leur date de construction. L\'amélioration énergétique offre d\'excellentes perspectives de valorisation immobilière.</p>
      </div>

      <div class="bg-peb-card border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Services
        </h3>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Certificat PEB premium</h4>
            <p class="text-peb-text2 text-sm">Certification pour villas de prestige.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Audit de prestige</h4>
            <p class="text-peb-text2 text-sm">Analyse approfondie des propriétés exceptionnelles.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Rapport d\'excellence</h4>
            <p class="text-peb-text2 text-sm">Documentation complète et stratégique.</p>
          </div>
          <div>
            <h4 class="font-semibold text-peb-cyan mb-2">Consultation villa</h4>
            <p class="text-peb-text2 text-sm">Expertise pour propriétés de prestige.</p>
          </div>
        </div>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Tarification
        </h3>
        <div class="grid sm:grid-cols-3 gap-4 mb-6">
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Petit bien</p>
            <p class="text-3xl font-bold text-peb-cyan">189€</p>
          </div>
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Duplex</p>
            <p class="text-3xl font-bold text-peb-cyan">219€</p>
          </div>
          <div class="bg-peb-surface border border-peb-border rounded-lg p-6">
            <p class="text-sm text-peb-text2 mb-2">Villa</p>
            <p class="text-3xl font-bold text-peb-cyan">249€+</p>
          </div>
        </div>
        <p class="text-peb-text2 mb-4">
          <a href="/contact/" class="text-peb-cyan hover:text-peb-green font-medium transition-colors">Devis personnalisé</a> pour villas exceptionnelles.
        </p>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Ressources
        </h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/guide-peb/definition/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Qu'est-ce que le PEB?</p>
            <p class="text-sm text-peb-text2">Comprendre.</p>
          </a>
          <a href="/guide-peb/ameliorer-score/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Améliorer votre score</p>
            <p class="text-sm text-peb-text2">Recommandations.</p>
          </a>
          <a href="/guide-peb/echelle-classes/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Classes énergétiques</p>
            <p class="text-sm text-peb-text2">A++ à G.</p>
          </a>
          <a href="/guide-peb/primes/" class="bg-peb-surface border border-peb-border rounded-lg p-4 hover:border-peb-cyan transition-colors">
            <p class="font-semibold text-peb-text mb-2">Aides rénovation</p>
            <p class="text-sm text-peb-text2">Primes 2026.</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faqItems} />

  <CTA
    title="Certificat PEB pour votre villa à Uccle"
    subtitle="Spécialiste des propriétés de prestige. Contactez-moi pour votre certification."
    primaryHref="/contact/"
    primaryText="Demander un devis"
    secondaryHref="/guide-peb/"
    secondaryText="En savoir plus"
  />

  <CommuneLinks />
</PageLayout>
