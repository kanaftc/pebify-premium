---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
import FAQ from '../../components/sections/FAQ.astro';
import CommuneLinks from '../../components/sections/CommuneLinks.astro';

const faqItems = [
  {
    question: 'Comment certifier une villa auprès du Parc de Woluwe?',
    answer: 'Les villas de Woluwe-Saint-Lambert, même auprès du Parc remarquable, se certifient de manière standard. La proximité du parc n\'affecte pas la certification. Je maîtrise l\'architecture typique woluwéenne.'
  },
  {
    question: 'Quel profil énergétique pour les villas woluwéennes?',
    answer: 'Les villas de Woluwe-Saint-Lambert obtiennent généralement C à F. L\'environnement naturel préservé reflète souvent des propriétés bien entretenues offrant bon potentiel.'
  },
  {
    question: 'Quel tarif pour une grande villa à Woluwe-Saint-Lambert?',
    answer: 'Pour les villas de Woluwe-Saint-Lambert, mon tarif est 249€ minimum. Contactez-moi pour les propriétés exceptionnelles. Je maîtrise bien ce territoire.'
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PEBify - Certificat PEB Woluwe-Saint-Lambert",
  "description": "Expert en certification PEB agréé à Woluwe-Saint-Lambert (1200)",
  "url": "https://pebify.be/certificat-peb-woluwe-saint-lambert/",
  "areaServed": { "@type": "City", "name": "Woluwe-Saint-Lambert", "postalCode": "1200" },
  "priceRange": "€€€"
};
---

<PageLayout
  title="Certificat PEB Woluwe-Saint-Lambert (1200) — Dès 189€ | Certificateur Agréé"
  description="Expert en certification PEB à Woluwe-Saint-Lambert (1200). Spécialiste des villas particulières et propriétés de prestige. Certificats énergétiques agréés complets."
  breadcrumb={[{ label: 'Certificat PEB Woluwe-Saint-Lambert', href: '/certificat-peb-woluwe-saint-lambert/' }]}
  heroLabel="Certification PEB"
  heroTitle="Certificat PEB à Woluwe-Saint-Lambert"
  heroSubtitle="Spécialiste de la certification énergétique à Woluwe-Saint-Lambert (1200). Expert en villas et propriétés de prestige."
  canonical="https://pebify.be/certificat-peb-woluwe-saint-lambert/"
  schemaJson={jsonLd}
>
  <section class="py-16 sm:py-20 md:py-24 bg-peb-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-display font-bold mb-6 text-peb-text">
          Certificat PEB à <span class="gradient-text-cyan">Woluwe-Saint-Lambert</span>
        </h2>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Woluwe-Saint-Lambert, commune du nord-est bruxellois, conjugue qualité de vie urbaine et environnement verdoyant remarquable. Avec plus de 55 000 habitants, elle offre un habitat résidentiel de qualité dominé par les villas particulières et les maisons spacieuses. Le Parc de Woluwe constituent le cœur naturel remarquable de cette commune.
        </p>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
          Je suis spécialisé dans la certification des villas et propriétés woluwéennes. Mon expertise approfondie me permet d'évaluer précisément ces biens de qualité avec exactitude et respect de leurs spécificités. Le Parc de Woluwe et ses environs offrent un cadre naturel exceptionnel pour optimiser les améliorations énergétiques.
        </p>
      </div>

      <div class="bg-peb-surface border border-peb-border rounded-xl p-8 mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Propriétés à Woluwe-Saint-Lambert
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Villas particulières</p>
              <p class="text-peb-text2 text-sm">Certification de villas spacieuses typiques.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Maisons spacieuses</p>
              <p class="text-peb-text2 text-sm">Certification de propriétés spacieuses de quality.</p>
            </div>
          </li>
          <li class="flex items-start space-x-4">
            <svg class="w-6 h-6 text-peb-cyan flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div>
              <p class="font-semibold text-peb-text">Habitats résidentiels</p>
              <p class="text-peb-text2 text-sm">Certification d'habitats variés de qualité.</p>
