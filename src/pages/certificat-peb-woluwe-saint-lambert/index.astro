              <p class="font-semibold text-peb-text">Propriétés de prestige</p>
              <p class="text-peb-text2 text-sm">Certification d'exception.</p>
            </div>
          </li>
        </ul>
      </div>

      <div class="mb-12 reveal">
        <h3 class="text-2xl font-display font-bold mb-6 text-peb-text">
          Profil énergétique
        </h3>
        <p class="text-lg text-peb-text2 mb-4 leading-relaxed">
